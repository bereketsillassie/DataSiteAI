{
  "name": "datasiteai",
  "version": "1.0.0",
  "description": "AI platform for analyzing data center impacts, land use, and environmental overlays",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\" --kill-others-on-fail",
    "api": "npm run dev -w backend",
    "web": "npm run dev -w frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bereketsillassie/DataSiteAI.git"
  },
  "keywords": [
    "ai",
    "geospatial",
    "data-centers",
    "environment",
    "analytics"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bereketsillassie/DataSiteAI/issues"
  },
  "homepage": "https://github.com/bereketsillassie/DataSiteAI#readme",
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}